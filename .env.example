# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/interviewverse
MONGODB_URI=mongodb://localhost:27017/interviewverse
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8080/v1/auth/google/callback

# ─── AI Providers ─────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
AI_PRIMARY_PROVIDER=openai

# ─── Voice ────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-key

# ─── File Storage ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret

# ─── Code Execution ───────────────────────────────────
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-judge0-key

# ─── Email ────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-key
EMAIL_FROM=noreply@interviewverse.ai

# ─── Monitoring ───────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn
POSTHOG_KEY=phc_your-posthog-key
